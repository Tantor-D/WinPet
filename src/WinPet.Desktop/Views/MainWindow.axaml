<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WinPet.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="620"
        d:DesignHeight="760"
        x:Class="WinPet.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/winpet-icon.ico"
        Width="620"
        Height="760"
        MinWidth="500"
        MinHeight="560"
        Title="WinPet 活动监测">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock FontSize="14"
                           Foreground="#697386"
                           Text="WINPET · 实时活动检测"/>
                <TextBlock FontSize="34"
                           FontWeight="SemiBold"
                           Text="{Binding StateText}"/>
                <TextBlock Foreground="#697386"
                           Text="{Binding LastUpdatedText}"/>
            </StackPanel>

            <Border Padding="22"
                    CornerRadius="18"
                    Background="#F0F5FF">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="#52647A"
                               Text="本轮连续工作"/>
                    <TextBlock FontFamily="Consolas"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Text="{Binding ContinuousWorkText}"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,16,*">
                <Border Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="#697386" Text="本轮活跃"/>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="22"
                                   Text="{Binding ActiveTimeText}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="#697386" Text="当前离开"/>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="22"
                                   Text="{Binding BreakTimeText}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="今日统计"/>
                <Grid ColumnDefinitions="*,12,*"
                      RowDefinitions="Auto,12,Auto,12,Auto">
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386" Text="电脑使用"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayComputerText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386" Text="活跃使用"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayActiveText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386"
                                       Text="最长工作轮次"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayLongestText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F4FAF5">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#52705A"
                                       Text="完成轮次 / 有效休息"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="20"
                                           Text="{Binding TodaySessionsText}"/>
                                <TextBlock FontSize="20" Text="/"/>
                                <TextBlock FontSize="20"
                                           Text="{Binding TodayBreaksText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFF5F2">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#8B5A4A"
                                       Text="今日超时工作"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayOvertimeText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4"
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFF8EA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#7A6336"
                                       Text="提醒次数"/>
                            <TextBlock FontSize="20"
                                       Text="{Binding TodayRemindersText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="今日活跃分布"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6">
                        <TextBlock Foreground="#697386"
                                   Text="高峰"/>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding PeakActivityText}"/>
                    </StackPanel>
                </Grid>
                <Border Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <ItemsControl ItemsSource="{Binding HourlyActivityBars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="24"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HourlyActivityBarViewModel">
                                <Grid Height="125"
                                      RowDefinitions="100,25"
                                      ToolTip.Tip="{Binding Tooltip}">
                                    <Border Width="12"
                                            Height="{Binding BarHeight}"
                                            MaxHeight="100"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Center"
                                            CornerRadius="4,4,1,1"
                                            Background="#6587E8"/>
                                    <TextBlock Grid.Row="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               FontSize="10"
                                               Foreground="#697386"
                                               Text="{Binding Label}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="最近 14 天"/>
                <Grid ColumnDefinitions="*,12,*">
                    <Border Padding="14"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="4">
                            <TextBlock Foreground="#697386"
                                       Text="近 7 天活跃"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding LastSevenDaysText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="14"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="4">
                            <TextBlock Foreground="#697386"
                                       Text="日均活跃"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding DailyAverageText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <Border Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <ItemsControl ItemsSource="{Binding DailyTrendBars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="14"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DailyTrendBarViewModel">
                                <Grid Height="130"
                                      RowDefinitions="100,30"
                                      ToolTip.Tip="{Binding Tooltip}">
                                    <Border Width="18"
                                            Height="{Binding BarHeight}"
                                            MaxHeight="100"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Center"
                                            CornerRadius="5,5,1,1"
                                            Background="#75C99A"/>
                                    <TextBlock Grid.Row="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               FontSize="9"
                                               Text="{Binding Label}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <Grid ColumnDefinitions="*,10,*,10,*">
                <Button Padding="12"
                        Command="{Binding ResetSessionCommand}"
                        Content="重置计时"/>
                <Button Grid.Column="2"
                        Padding="12"
                        Command="{Binding TogglePauseCommand}"
                        Content="暂停 / 继续"/>
                <Button Grid.Column="4"
                        Padding="12"
                        Command="{Binding OpenSettingsCommand}"
                        Content="设置"/>
            </Grid>
            <Grid ColumnDefinitions="*,10,*">
                <Button Padding="12"
                        Command="{Binding ExportDataCommand}"
                        Content="导出 CSV 压缩包"/>
                <Button Grid.Column="2"
                        Padding="12"
                        Command="{Binding RequestClearDataCommand}"
                        Content="清除全部历史"/>
            </Grid>
            <TextBlock Foreground="#697386"
                       TextWrapping="Wrap"
                       Text="{Binding DataStatusText}"/>
        </StackPanel>
    </ScrollViewer>
</Window>
