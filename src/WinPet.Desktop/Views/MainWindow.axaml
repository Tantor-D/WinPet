<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WinPet.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="620"
        d:DesignHeight="760"
        x:Class="WinPet.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="620"
        Height="760"
        MinWidth="500"
        MinHeight="560"
        Title="WinPet 活动监测">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock FontSize="14"
                           Foreground="#697386"
                           Text="WINPET · 实时活动检测"/>
                <TextBlock FontSize="34"
                           FontWeight="SemiBold"
                           Text="{Binding StateText}"/>
                <TextBlock Foreground="#697386"
                           Text="{Binding LastUpdatedText}"/>
            </StackPanel>

            <Border Padding="22"
                    CornerRadius="18"
                    Background="#F0F5FF">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="#52647A"
                               Text="本轮连续工作"/>
                    <TextBlock FontFamily="Consolas"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Text="{Binding ContinuousWorkText}"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,16,*">
                <Border Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="#697386" Text="本轮活跃"/>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="22"
                                   Text="{Binding ActiveTimeText}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Padding="18"
                        CornerRadius="14"
                        Background="#F7F8FA">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="#697386" Text="当前离开"/>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="22"
                                   Text="{Binding BreakTimeText}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="今日统计"/>
                <Grid ColumnDefinitions="*,12,*"
                      RowDefinitions="Auto,12,Auto,12,Auto">
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386" Text="电脑使用"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayComputerText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386" Text="活跃使用"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayActiveText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F7F8FA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#697386"
                                       Text="最长工作轮次"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayLongestText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#F4FAF5">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#52705A"
                                       Text="完成轮次 / 有效休息"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="20"
                                           Text="{Binding TodaySessionsText}"/>
                                <TextBlock FontSize="20" Text="/"/>
                                <TextBlock FontSize="20"
                                           Text="{Binding TodayBreaksText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFF5F2">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#8B5A4A"
                                       Text="今日超时工作"/>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="20"
                                       Text="{Binding TodayOvertimeText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4"
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFF8EA">
                        <StackPanel Spacing="5">
                            <TextBlock Foreground="#7A6336"
                                       Text="提醒次数"/>
                            <TextBlock FontSize="20"
                                       Text="{Binding TodayRemindersText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <Button HorizontalAlignment="Stretch"
                    Padding="16,12"
                    Command="{Binding ResetSessionCommand}"
                    Content="重置本轮工作时间"/>
        </StackPanel>
    </ScrollViewer>
</Window>
